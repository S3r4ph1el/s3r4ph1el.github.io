---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Rubric from '../../components/Rubric.astro';
import Dinkus from '../../components/Dinkus.astro';
import '../../styles/about.css';

const entry = await getEntry('about', 'en');
if (!entry) throw new Error('about/en content missing');
const { Content } = await render(entry);
---
<BaseLayout
  title="Vita · s3r4ph1el"
  description="Enzo Teles (S3r4ph1el) — Offensive Security Analyst, former Brazilian Army officer."
  lang="en"
>
  <div class="terminal-wrap about-wrap">
    <Breadcrumb trail={[
      { label: 'Index', href: '/en/' },
      { label: 'Vita' },
    ]} />

    <PageHeader
      epigraph="Man's life upon earth is a warfare."
      attribution="Iob 7, 1 · Vulgata"
    />

    <Rubric
      numeral="IV"
      title="Vita"
      subtitle="The work under the light of the craft."
    />

    <article class="about-article">
      <Content />
    </article>

    <Dinkus />
  </div>
</BaseLayout>

<style>
  .about-wrap { max-width: 880px; }
  .about-article :global(h2) {
    border: none;
    padding: 0;
    margin: 0;
  }
  .about-article :global(.about-intro::first-letter) {
    font-family: var(--font-serif);
    font-weight: 700;
    color: var(--red);
    float: left;
    font-size: 3.4em;
    line-height: 0.88;
    padding: 0.08em 0.35ch 0 0;
    margin-right: 0.1ch;
  }
</style>
