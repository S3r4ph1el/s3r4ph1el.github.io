---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Rubric from '../../../components/Rubric.astro';
import EmptyState from '../../../components/EmptyState.astro';
import EntryList from '../../../components/EntryList.astro';

const entries = await getCollection('blog', (e) =>
  !e.data.draft && e.data.locale === 'en'
);
entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const listEntries = entries.map((e) => ({
  href: `/en/scripta/${e.slug}/`,
  title: e.data.title,
  date: e.data.date,
  description: e.data.description,
  meta: e.data.tags,
}));
---
<BaseLayout
  title="Scripta · S3r4ph1el"
  description="Essays and technical notes on Offensive Security — S3r4ph1el."
  lang="en"
>
  <div class="terminal-wrap narrow">
    <Breadcrumb trail={[
      { label: 'Index', href: '/en/' },
      { label: 'Scripta' },
    ]} />

    <Rubric
      numeral="I"
      title="Scripta"
      subtitle="Essays and technical notes on the craft."
    />

    {listEntries.length === 0 ? (
      <EmptyState
        latin="Nondum scripta sunt."
        vern="No writings published yet."
      />
    ) : (
      <EntryList entries={listEntries} lang="en" />
    )}
  </div>
</BaseLayout>

<style>
  .narrow { max-width: 880px; }
</style>
