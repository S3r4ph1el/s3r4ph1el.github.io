---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  widths?: number[];
  sizes?: string;
  priority?: boolean;
}

const {
  src,
  alt,
  caption,
  widths = [400, 800, 1200],
  sizes = '(max-width: 720px) 100vw, 720px',
  priority = false,
} = Astro.props;
---
<figure class="ill-figure">
  <Image
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    loading={priority ? 'eager' : 'lazy'}
    decoding={priority ? 'sync' : 'async'}
    formats={['avif', 'webp']}
  />
  {caption && <figcaption>{caption}</figcaption>}
</figure>
