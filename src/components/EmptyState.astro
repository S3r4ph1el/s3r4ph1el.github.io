---
interface Props {
  latin: string;
  vern?: string;
  ornament?: string;
}
const { latin, vern, ornament = '✠' } = Astro.props;
---
<div class="empty-state" role="status">
  <span class="orn" aria-hidden="true">{ornament}</span>
  <p class="latin"><em>{latin}</em></p>
  {vern && <p class="vern">({vern})</p>}
</div>
