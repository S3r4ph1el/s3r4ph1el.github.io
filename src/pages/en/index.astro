---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Rubric from '../../components/Rubric.astro';
import Dinkus from '../../components/Dinkus.astro';
import SectionCard from '../../components/SectionCard.astro';
import ContactCard from '../../components/ContactCard.astro';
import SeraphimGloss from '../../components/SeraphimGloss.astro';

const [blog, projects, writeups] = await Promise.all([
  getCollection('blog', (e) => !e.data.draft && e.data.locale === 'en'),
  getCollection('projects', (e) => !e.data.draft && e.data.locale === 'en'),
  getCollection('writeups', (e) => !e.data.draft && e.data.locale === 'en'),
]);
---
<BaseLayout
  title="S3r4ph1el"
  description="Personal blog by Enzo Teles (S3r4ph1el) — HTB / Hacking Club writeups, projects, and Offensive Security articles."
  lang="en"
>
  <SeraphimGloss lang="en" />

  <div class="terminal-wrap home">
    <PageHeader
      variant="hero"
      byline="Enzo Teles"
      epigraph="Blessed be the Lord my God, which teacheth my hands to war, and my fingers to fight."
      attribution="Ps. 143, 1 · Vulgata"
    />

    <div class="hero-cta">
      <p class="role-line">Offensive Security Analyst</p>
      <a class="ghost-link" href="/en/vita/">Vita</a>
    </div>

    <Rubric numeral="§" title="Index" />

    <div class="section-grid">
      <SectionCard
        numeral="I"
        latin="Scripta"
        href="/en/scripta/"
        count={blog.length}
        unit={blog.length === 1 ? 'article' : 'articles'}
        subtitle="Essays and technical notes."
      />
      <SectionCard
        numeral="II"
        latin="Opera"
        href="/en/opera/"
        count={projects.length}
        unit={projects.length === 1 ? 'project' : 'projects'}
        subtitle="Code and tools."
      />
      <SectionCard
        numeral="III"
        latin="Acta"
        href="/en/acta/"
        count={writeups.length}
        unit={writeups.length === 1 ? 'writeup' : 'writeups'}
        subtitle="Hack The Box, Hacking Club and CTFs."
      />
    </div>

    <Rubric numeral="§" title="Contactus" />

    <div class="contact-grid">
      <ContactCard label="GitHub" href="https://github.com/S3r4ph1el" />
      <ContactCard label="LinkedIn" href="https://linkedin.com/in/enzo-teles" />
      <ContactCard label="Email" handle="ezteles.px@gmail.com" href="mailto:ezteles.px@gmail.com" external={false} />
    </div>

    <Rubric numeral="§" title="Platforms" />

    <div class="contact-grid platforms">
      <ContactCard label="Hack The Box" href="https://app.hackthebox.com/public/users/2124077" />
      <ContactCard label="Hacking Club" href="https://app.hackingclub.com/profile/user/21053" />
    </div>
  </div>
</BaseLayout>
